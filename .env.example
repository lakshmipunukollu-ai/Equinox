# ─── Kalshi V1 API (optional) ────────────────────────────────────────────────
# Required only if the Kalshi V1 endpoint returns 401 without auth.
# Leave blank to attempt unauthenticated access first.
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=./kalshi_private_key.pem

# ─── Hugging Face (optional) ─────────────────────────────────────────────────
# Set HF_TOKEN for higher rate limits and faster model downloads (sentence-transformers).
# Get a token at https://huggingface.co/settings/tokens
HF_TOKEN=

# ─── Matching thresholds ─────────────────────────────────────────────────────
FUZZY_THRESHOLD=0.75
SEMANTIC_THRESHOLD=0.82
DATE_WINDOW_DAYS=3

# ─── Routing scoring caps ─────────────────────────────────────────────────────
# LIQUIDITY_CAP has been removed. The liquidity score is now order-size-aware:
#   liquidity_score = 1.0 - (order_size / market.liquidity)
# There is no cap — the formula naturally produces 0.0 when the order exceeds
# available liquidity. Do NOT re-add LIQUIDITY_CAP without updating the formula.
#
# VOLUME_CAP: markets at or above this value score 1.0 on volume component.
# Kalshi volume is in contracts; Polymarket volume is in USD — units differ.
VOLUME_CAP=100000

# ─── Venue fee rates ──────────────────────────────────────────────────────────
# These are approximations — neither venue exposes fee data per market via API.
# Update when accurate programmatic fee data becomes available.
# Kalshi: ~7¢ per contract taker fee — ADDITIVE (flat cost, not % of price)
#   all_in_price = yes_price + KALSHI_FEE_RATE
KALSHI_FEE_RATE=0.07
# Polymarket: ~2% protocol fee — MULTIPLICATIVE (% of trade value)
#   all_in_price = yes_price * (1 + POLYMARKET_FEE_RATE)
POLYMARKET_FEE_RATE=0.02
# Fee cap: fee_score = 0.0 when fee friction reaches this value (in ¢).
# 10¢ fee burden = score 0.0; 0¢ fee burden = score 1.0.
FEE_CAP=0.10
# Bid-ask spread at which execution_score floors to 0.0 (worst).
SPREAD_WIDTH_CAP=0.20

# ─── Polymarket (production / proxy) ─────────────────────────────────────────
# If Polymarket blocks or rate-limits cloud IPs (e.g. Railway), set a proxy base URL.
# POLYMARKET_API_BASE_URL=https://your-proxy.example.com/polymarket
# Bump timeout in production if fetches often time out (default 8s).
# POLYMARKET_TIMEOUT_SECONDS=20

# ─── Timeouts (optional) ──────────────────────────────────────────────────────
# KALSHI_TIMEOUT_SECONDS=8
# POLYMARKET_TIMEOUT_SECONDS=8

# ─── Storage ─────────────────────────────────────────────────────────────────
DB_PATH=equinox.db
LOG_PATH=logs/equinox.log
